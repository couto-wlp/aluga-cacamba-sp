---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog | Dicas e Regulamentações | Aluga Caçamba SP" description="Confira notícias, dicas de descarte correto de entulhos e regras de caçambas estacionárias em São Paulo.">
	<section class="bg-gradient-to-b from-slate-100 to-white">
		<div class="container mx-auto px-6 md:px-12">
			<!-- H1 with font-black tracking-tighter mb-16 -->
			<h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-slate-900 tracking-tighter mb-16 leading-tight">
				Blog
			</h1>

			<!-- Grid with gap-10/12, Cards with p-10/12 and hover scaling -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12">
				{posts.map((post) => (
					<div class="bg-white rounded-3xl border border-slate-200/60 p-10 hover:scale-105 hover:shadow-xl hover:border-slate-300 transition-all duration-300 flex flex-col justify-between cursor-pointer">
						<div>
							<span class="text-xs font-bold text-slate-400 uppercase tracking-widest block mb-3">
								{post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
							</span>
							<h2 class="text-2xl font-black text-slate-900 tracking-tighter mb-4 hover:text-secondary transition-colors">
								<a href={`/blog/${post.slug}`}>{post.data.title}</a>
							</h2>
							<p class="text-slate-650 text-sm leading-relaxed mb-6">
								{post.data.description}
							</p>
						</div>
						<a href={`/blog/${post.slug}`} class="inline-flex items-center text-sm font-black text-secondary hover:text-amber-500 transition-colors gap-1">
							Ler Artigo Completo <span>→</span>
						</a>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
