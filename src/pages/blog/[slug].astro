---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE_CONFIG } from '../../data/config';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Query related posts (exclude current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts.filter(p => p.slug !== post.slug).slice(0, 2);
---

<Layout title={`${post.data.title} | Blog | Aluga Caçamba SP`} description={post.data.description}>
	<section class="bg-gradient-to-b from-slate-100 to-white">
		<div class="container mx-auto px-6 md:px-12">
			<!-- Link back -->
			<div class="max-w-6xl mx-auto mb-8">
				<a href="/blog" class="text-sm font-semibold text-slate-500 hover:text-secondary transition-colors">
					← Voltar ao Blog
				</a>
			</div>
			
			<!-- H1 large with mb-16, font-black, tracking-tighter -->
			<h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-slate-900 tracking-tighter mb-16 leading-tight max-w-6xl mx-auto">
				{post.data.title}
			</h1>

			<!-- 2-Column Portal de Notícias Grid -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start max-w-6xl mx-auto">
				<!-- Left Column: Article (lg:col-span-2) -->
				<div class="lg:col-span-2 space-y-8">
					<article class="prose prose-slate prose-lg max-w-none bg-white p-10 md:p-12 rounded-3xl border border-slate-200/80 shadow-md">
						<div class="mb-8 text-xs font-bold text-slate-400 uppercase tracking-wider">
							Publicado em {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
						</div>
						<Content />
					</article>
				</div>

				<!-- Right Column: Sidebar (lg:col-span-1) -->
				<div class="lg:col-span-1">
					<div class="sticky top-28 bg-secondary text-white p-8 rounded-3xl border border-secondary/20 shadow-xl space-y-6 hover:scale-102 transition-transform duration-300">
						<!-- Title in text-primary -->
						<h3 class="text-2xl font-black text-primary tracking-tighter leading-tight">Precisa Alugar Caçamba?</h3>
						<!-- Body in high contrast white/slate-100 -->
						<p class="text-sm text-slate-100 leading-relaxed">
							Atendemos obras comerciais e residenciais em São Paulo com pontualidade. Peça orçamento e agende hoje mesmo.
						</p>
						<div class="border-t border-white/10 pt-4 space-y-4">
							<a href={SITE_CONFIG.whatsapp.link} target="_blank" rel="noopener noreferrer" class="w-full py-4 bg-primary text-accent hover:bg-yellow-400 rounded-xl font-black text-base flex items-center justify-center gap-2 hover:scale-105 active:scale-95 transition-all duration-200 shadow-lg shadow-primary/20">
								<!-- WhatsApp SVG -->
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0 fill-accent" viewBox="0 0 24 24">
									<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.719-1.455L0 24zm6.59-4.846c1.6.95 3.498 1.453 5.418 1.454h.005c5.548 0 10.061-4.515 10.064-10.067.002-2.69-1.043-5.22-2.943-7.123C17.23 1.516 14.7 1.011 12.008 1.01 6.458 1.01 1.947 5.524 1.944 11.077c-.001 1.916.501 3.788 1.457 5.4l-.956 3.493 3.585-.94c1.552.846 3.298 1.291 5.068 1.291z M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
								</svg>
								Pedir Orçamento
							</a>
							<a href={`tel:${SITE_CONFIG.phone.number}`} class="w-full py-4 border border-white/20 hover:bg-white/10 rounded-xl font-bold text-center block text-sm transition-all hover:scale-105 active:scale-95 duration-200 text-white">
								Ligar {SITE_CONFIG.phone.display}
							</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Outras Dicas Section (Related posts) -->
			{relatedPosts.length > 0 && (
				<div class="border-t border-slate-200/80 pt-16 mt-16 max-w-6xl mx-auto">
					<h2 class="text-3xl font-black text-slate-900 tracking-tighter leading-tight mb-8">Outras Dicas de Obra</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12">
						{relatedPosts.map(p => (
							<div class="bg-white rounded-3xl border border-slate-200/60 p-10 hover:scale-105 hover:shadow-xl transition-all duration-300 flex flex-col justify-between cursor-pointer">
								<div>
									<span class="text-xs font-bold text-slate-400 uppercase tracking-widest block mb-3">
										{p.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
									</span>
									<h3 class="text-xl font-black text-slate-900 tracking-tighter mb-4 hover:text-secondary transition-colors">
										<a href={`/blog/${p.slug}`}>{p.data.title}</a>
									</h3>
									<p class="text-slate-650 text-sm leading-relaxed mb-6">
										{p.data.description}
									</p>
								</div>
								<a href={`/blog/${p.slug}`} class="inline-flex items-center text-sm font-black text-secondary hover:text-amber-500 transition-colors gap-1">
									Ler Artigo Completo <span>→</span>
								</a>
							</div>
						))}
					</div>
				</div>
			)}
		</div>
	</section>
</Layout>
