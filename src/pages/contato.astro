---
import Layout from '../layouts/Layout.astro';
import { SITE_CONFIG } from '../data/config';
---

<Layout title="Fale Conosco | Aluga Caçamba SP" description="Fale com a Aluga Caçamba SP para orçamentos rápidos e entrega programada de caçambas estacionárias em São Paulo.">
	<section class="bg-gradient-to-b from-slate-100 to-white">
		<div class="container mx-auto px-6 md:px-12">
			<!-- H1 large with mb-16, tracking-tighter -->
			<h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-slate-900 tracking-tighter mb-16 leading-tight">
				Contato
			</h1>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
				<!-- High-conversion form card (p-10 padding, border, hover animation) -->
				<div class="bg-white rounded-3xl border border-slate-200/80 p-10 shadow-lg shadow-slate-100/50 hover:shadow-xl transition-all duration-300">
					<h2 class="text-2xl font-black text-slate-900 mb-6 tracking-tighter">Envie uma Mensagem</h2>
					<form class="space-y-6" onsubmit="event.preventDefault(); alert('Mensagem enviada com sucesso! Entraremos em contato em breve.');">
						<div>
							<label for="name" class="block text-sm font-bold text-slate-700 mb-2">Nome Completo</label>
							<input type="text" id="name" name="name" required class="w-full p-6 text-base rounded-xl border border-slate-200 focus:outline-none focus:border-secondary focus:ring-2 focus:ring-secondary/10 bg-slate-50 text-slate-900 transition" placeholder="Seu nome" />
						</div>
						<div>
							<label for="phone" class="block text-sm font-bold text-slate-700 mb-2">Telefone com WhatsApp</label>
							<input type="tel" id="phone" name="phone" required class="w-full p-6 text-base rounded-xl border border-slate-200 focus:outline-none focus:border-secondary focus:ring-2 focus:ring-secondary/10 bg-slate-50 text-slate-900 transition" placeholder="(11) 99999-9999" />
						</div>
						<div>
							<label for="message" class="block text-sm font-bold text-slate-700 mb-2">Detalhes da Solicitação</label>
							<textarea id="message" name="message" rows="4" required class="w-full p-6 text-base rounded-xl border border-slate-200 focus:outline-none focus:border-secondary focus:ring-2 focus:ring-secondary/10 bg-slate-50 text-slate-900 transition" placeholder="Descreva o local da obra e a caçamba que precisa..."></textarea>
						</div>
						<button type="submit" class="w-full p-6 bg-accent hover:bg-slate-800 text-white font-extrabold text-base rounded-xl transition duration-200 hover:scale-102 active:scale-95 flex items-center justify-center gap-2">
							Enviar Solicitação
						</button>
					</form>
				</div>

				<!-- NAP & WhatsApp CTA block -->
				<div class="flex flex-col justify-between gap-10">
					<!-- Local SEO NAP details card -->
					<div class="bg-slate-50 border border-slate-200/60 rounded-3xl p-10 flex flex-col justify-between h-full shadow-sm">
						<div>
							<h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tighter">Dados de Contato (NAP)</h2>
							
							<div class="space-y-6 text-slate-700 mb-10">
								<div>
									<p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Nome da Empresa</p>
									<p class="text-lg font-bold text-slate-900">{SITE_CONFIG.name}</p>
								</div>
								<div>
									<p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Endereço Principal</p>
									<p class="text-lg font-bold text-slate-900">{SITE_CONFIG.address.formatted}</p>
								</div>
								<div>
									<p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Telefone Fixo</p>
									<p class="text-lg font-bold text-slate-900">
										<a href={`tel:${SITE_CONFIG.phone.number}`} class="hover:text-secondary hover:underline">{SITE_CONFIG.phone.display}</a>
									</p>
								</div>
								<div>
									<p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">WhatsApp Atendimento</p>
									<p class="text-lg font-bold text-slate-900 text-primary bg-accent inline-block px-3 py-1.5 rounded-lg">
										<a href={SITE_CONFIG.whatsapp.link} target="_blank" rel="noopener noreferrer" class="hover:underline">{SITE_CONFIG.whatsapp.display}</a>
									</p>
								</div>
							</div>
						</div>

						<!-- WhatsApp CTA with p-8 padding -->
						<a href={SITE_CONFIG.whatsapp.link} target="_blank" rel="noopener noreferrer" class="w-full p-8 bg-primary text-accent hover:bg-yellow-400 rounded-2xl font-black text-lg flex items-center justify-center gap-3 hover:scale-105 active:scale-95 transition-all duration-200 shadow-xl shadow-primary/25">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 flex-shrink-0 fill-accent" viewBox="0 0 24 24">
								<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.719-1.455L0 24zm6.59-4.846c1.6.95 3.498 1.453 5.418 1.454h.005c5.548 0 10.061-4.515 10.064-10.067.002-2.69-1.043-5.22-2.943-7.123C17.23 1.516 14.7 1.011 12.008 1.01 6.458 1.01 1.947 5.524 1.944 11.077c-.001 1.916.501 3.788 1.457 5.4l-.956 3.493 3.585-.94c1.552.846 3.298 1.291 5.068 1.291z M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
							</svg>
							Fale com Atendente no WhatsApp
						</a>
					</div>
				</div>
			</div>

			<!-- Map Section -->
			<div class="mt-16 bg-white rounded-3xl border border-slate-200/80 p-6 shadow-lg shadow-slate-100/50 hover:shadow-xl transition-all duration-300">
				<h2 class="text-2xl font-black text-slate-900 mb-6 tracking-tighter px-2">Nossa Área de Atendimento</h2>
				<div class="rounded-2xl overflow-hidden border border-slate-100 h-[400px] relative w-full">
					<iframe 
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3657.197597011985!2d-46.658602!3d-23.561706!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce59c8da0aa315%3A0xd59f9431f2c9776a!2sAv.%20Paulista%2C%201000%20-%20Bela%20Vista%2C%20S%C3%A3o%20Paulo%20-%20SP%2C%2001310-100!5e0!3m2!1spt-BR!2sbr!5m2!1spt-BR!2sbr" 
						width="100%" 
						height="100%" 
						style="border:0;" 
						allowfullscreen="" 
						loading="lazy" 
						referrerpolicy="no-referrer-when-downgrade"
						class="absolute inset-0 w-full h-full border-0"
						title="Mapa de Localização da Aluga Caçamba SP na Av. Paulista"
					></iframe>
				</div>
			</div>
		</div>
	</section>
</Layout>
