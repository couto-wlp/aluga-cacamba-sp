---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE_CONFIG } from '../../data/config';

const services = await getCollection('servicos');
---

<Layout 
	title="Nossos Serviços | Aluguel de Caçamba de Entulho | Aluga Caçamba SP" 
	description="Alugue caçambas estacionárias licenciadas pela prefeitura de São Paulo. Modelos de 3m³, 4m³ e 5m³. Atendimento rápido, CTR garantido e descarte legal."
>
	<!-- 1. Hero Section -->
	<section class="relative overflow-hidden bg-gradient-to-b from-slate-100 to-white border-b border-slate-200/60 py-20 md:py-24">
		<div class="absolute top-1/4 right-1/4 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[120px] pointer-events-none"></div>
		<div class="container mx-auto px-6 md:px-12 relative z-10 text-center max-w-4xl">
			<span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-black bg-secondary/10 text-secondary mb-6 border border-secondary/20 uppercase tracking-widest">
				🛠️ Serviços 100% Legalizados
			</span>
			<h1 class="text-4xl sm:text-5xl md:text-6xl font-black text-slate-900 tracking-tighter leading-tight mb-6">
				Aluguel de Caçambas para <span class="text-secondary">Qualquer Obra</span>
			</h1>
			<p class="text-lg md:text-xl text-slate-600 leading-relaxed max-w-2xl mx-auto">
				Disponibilizamos caçambas estacionárias devidamente sinalizadas e em conformidade com as regras da prefeitura para descarte correto de entulho e resíduos industriais.
			</p>
		</div>
	</section>

	<!-- 2. Catalog Grid Section -->
	<section class="bg-white py-24 md:py-32">
		<div class="container mx-auto px-6 md:px-12">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tighter mb-4 leading-tight">
					Escolha a Caçamba Ideal
				</h2>
				<p class="text-lg text-slate-600">
					Compare dimensões e capacidades e encontre o modelo ideal para as necessidades da sua obra.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
				{services.map((service) => (
					<div class="bg-slate-50 rounded-3xl border border-slate-200/40 p-10 md:p-12 hover:scale-105 hover:shadow-xl hover:border-slate-300 transition-all duration-300 flex flex-col justify-between cursor-pointer">
						<div>
							{service.data.image && (
								<div class="mb-6 overflow-hidden rounded-2xl border border-slate-200">
									<img src={service.data.image} alt={service.data.title} class="w-full h-48 object-cover hover:scale-105 transition duration-300" />
								</div>
							)}
							<span class="inline-block px-3 py-1.5 rounded-lg text-xs font-black bg-secondary text-primary mb-6">
								{service.data.capacity}
							</span>
							<h3 class="text-2xl font-black text-slate-900 tracking-tighter mb-4">
								{service.data.title}
							</h3>
							<p class="text-slate-600 text-sm leading-relaxed mb-6">
								{service.data.description}
							</p>
							<div class="border-t border-slate-200 pt-4 mb-6">
								<p class="text-xs text-slate-400 font-bold uppercase mb-1">Dimensões Externas:</p>
								<p class="text-sm text-slate-700 font-bold">{service.data.dimensions}</p>
							</div>
						</div>
						<div class="space-y-3 pt-4 border-t border-slate-200/60">
							<a href={`/servicos/${service.slug}`} class="inline-flex items-center justify-center w-full py-3.5 rounded-xl font-bold border border-slate-300 text-slate-700 hover:bg-slate-100 hover:scale-102 active:scale-98 transition-all text-sm">
								Especificações Técnicas
							</a>
							<a href={SITE_CONFIG.whatsapp.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-full py-3.5 rounded-xl font-bold bg-primary text-accent hover:bg-yellow-400 hover:scale-102 active:scale-98 transition-all text-sm gap-2">
								<!-- Phone SVG inside Button -->
								<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 fill-accent" viewBox="0 0 24 24">
									<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.719-1.455L0 24zm6.59-4.846c1.6.95 3.498 1.453 5.418 1.454h.005c5.548 0 10.061-4.515 10.064-10.067.002-2.69-1.043-5.22-2.943-7.123C17.23 1.516 14.7 1.011 12.008 1.01 6.458 1.01 1.947 5.524 1.944 11.077c-.001 1.916.501 3.788 1.457 5.4l-.956 3.493 3.585-.94c1.552.846 3.298 1.291 5.068 1.291z"/>
								</svg>
								Alugar Agora
							</a>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- 3. How It Works Section -->
	<section class="bg-slate-50 py-24 md:py-32 border-t border-b border-slate-100">
		<div class="container mx-auto px-6 md:px-12">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tighter mb-4 leading-tight">
					Como Funciona o Serviço?
				</h2>
				<p class="text-lg text-slate-650">
					Estruturamos a logística de entulho de ponta a ponta de forma simples e transparente.
				</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
				<!-- Step 1 -->
				<div class="bg-white p-8 rounded-3xl border border-slate-200/30 shadow-sm flex flex-col justify-between hover:scale-102 transition-transform duration-300">
					<div>
						<div class="w-12 h-12 rounded-2xl bg-secondary text-primary font-black flex items-center justify-center text-lg mb-6">
							01
						</div>
						<h4 class="text-lg font-bold text-slate-900 mb-3">Escolha o Tamanho</h4>
						<p class="text-xs text-slate-600 leading-relaxed">
							Selecione entre os modelos de 3m³, 4m³ ou 5m³ de acordo com o volume de entulho da sua obra.
						</p>
					</div>
				</div>

				<!-- Step 2 -->
				<div class="bg-white p-8 rounded-3xl border border-slate-200/30 shadow-sm flex flex-col justify-between hover:scale-102 transition-transform duration-300">
					<div>
						<div class="w-12 h-12 rounded-2xl bg-secondary text-primary font-black flex items-center justify-center text-lg mb-6">
							02
						</div>
						<h4 class="text-lg font-bold text-slate-900 mb-3">Agendamento</h4>
						<p class="text-xs text-slate-600 leading-relaxed">
							Defina o melhor local, dia e horário para a entrega via WhatsApp. Respondemos em poucos minutos.
						</p>
					</div>
				</div>

				<!-- Step 3 -->
				<div class="bg-white p-8 rounded-3xl border border-slate-200/30 shadow-sm flex flex-col justify-between hover:scale-102 transition-transform duration-300">
					<div>
						<div class="w-12 h-12 rounded-2xl bg-secondary text-primary font-black flex items-center justify-center text-lg mb-6">
							03
						</div>
						<h4 class="text-lg font-bold text-slate-900 mb-3">Uso Regulamentado</h4>
						<p class="text-xs text-slate-600 leading-relaxed">
							A caçamba permanece no local conforme a legislação municipal. Respeite as regras de carga e via pública.
						</p>
					</div>
				</div>

				<!-- Step 4 -->
				<div class="bg-white p-8 rounded-3xl border border-slate-200/30 shadow-sm flex flex-col justify-between hover:scale-102 transition-transform duration-300">
					<div>
						<div class="w-12 h-12 rounded-2xl bg-secondary text-primary font-black flex items-center justify-center text-lg mb-6">
							04
						</div>
						<h4 class="text-lg font-bold text-slate-900 mb-3">Destinação Correta</h4>
						<p class="text-xs text-slate-600 leading-relaxed">
							Fazemos a retirada dos resíduos e encaminhamos para aterros licenciados com a emissão da guia CTR.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 4. LIMPURB Compliance Callout -->
	<section class="bg-secondary text-white py-16">
		<div class="container mx-auto px-6 md:px-12 text-center max-w-3xl">
			<h3 class="text-2xl md:text-3xl font-black tracking-tight mb-4">
				Licenciamento LIMPURB & CTR Garantido
			</h3>
			<p class="text-base text-slate-200 leading-relaxed mb-6">
				A **Aluga Caçamba SP** é cadastrada formalmente nos órgãos de controle urbano. Geramos o Controle de Transporte de Resíduos (CTR) eletrônico para assegurar a destinação correta do entulho e afastar o risco de penalidades e multas fiscais em sua obra.
			</p>
			<div class="inline-flex items-center gap-4 text-xs font-bold bg-white/10 px-4 py-2 rounded-full border border-white/10 uppercase tracking-widest text-slate-100">
				<span>🛡️ Frota Rastreada</span>
				<span>•</span>
				<span>🌱 ATT Homologada</span>
			</div>
		</div>
	</section>

	<!-- 5. FAQ Accordion Section -->
	<section class="bg-white py-24 md:py-32">
		<div class="container mx-auto px-6 md:px-12">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tighter mb-4 leading-tight">
					Perguntas Frequentes
				</h2>
				<p class="text-lg text-slate-650">
					Esclareça suas dúvidas técnicas e práticas sobre a locação de caçambas estacionárias.
				</p>
			</div>

			<div class="max-w-3xl mx-auto space-y-4">
				<!-- FAQ Item 1 -->
				<div class="border border-slate-200 rounded-3xl overflow-hidden bg-slate-50 transition-colors duration-300 faq-item">
					<button class="w-full flex justify-between items-center p-6 md:p-8 text-left focus:outline-none select-none faq-trigger">
						<span class="font-extrabold text-base md:text-lg text-slate-900 leading-tight">Quanto tempo a caçamba pode permanecer na rua?</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 transition-transform duration-300 faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
						</svg>
					</button>
					<div class="max-h-0 overflow-hidden transition-all duration-300 faq-content">
						<div class="px-6 pb-6 md:px-8 md:pb-8 text-xs md:text-sm text-slate-600 leading-relaxed border-t border-slate-200/50 pt-4">
							De acordo com o regulamento do município de São Paulo, o período máximo para que uma caçamba estacionária fique posicionada na via pública é de 3 dias úteis. Caso precise de mais tempo em estacionamentos internos ou garagens, os termos adicionais podem ser combinados no momento do agendamento.
						</div>
					</div>
				</div>

				<!-- FAQ Item 2 -->
				<div class="border border-slate-200 rounded-3xl overflow-hidden bg-slate-50 transition-colors duration-300 faq-item">
					<button class="w-full flex justify-between items-center p-6 md:p-8 text-left focus:outline-none select-none faq-trigger">
						<span class="font-extrabold text-base md:text-lg text-slate-900 leading-tight">Quais materiais não podem ser jogados na caçamba?</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 transition-transform duration-300 faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
						</svg>
					</button>
					<div class="max-h-0 overflow-hidden transition-all duration-300 faq-content">
						<div class="px-6 pb-6 md:px-8 md:pb-8 text-xs md:text-sm text-slate-600 leading-relaxed border-t border-slate-200/50 pt-4">
							Não é permitido o descarte de resíduos domésticos/orgânicos, resíduos infectantes, pneus, lixo eletrônico, pilhas, tintas líquidas, solventes, combustíveis ou qualquer outro produto químico corrosivo ou inflamável. As caçambas devem ser utilizadas estritamente para resíduos sólidos e entulhos de construção e demolição.
						</div>
					</div>
				</div>

				<!-- FAQ Item 3 -->
				<div class="border border-slate-200 rounded-3xl overflow-hidden bg-slate-50 transition-colors duration-300 faq-item">
					<button class="w-full flex justify-between items-center p-6 md:p-8 text-left focus:outline-none select-none faq-trigger">
						<span class="font-extrabold text-base md:text-lg text-slate-900 leading-tight">É possível estacionar a caçamba em vagas de Zona Azul?</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 transition-transform duration-300 faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
						</svg>
					</button>
					<div class="max-h-0 overflow-hidden transition-all duration-300 faq-content">
						<div class="px-6 pb-6 md:px-8 md:pb-8 text-xs md:text-sm text-slate-600 leading-relaxed border-t border-slate-200/50 pt-4">
							Sim, o estacionamento de caçambas em áreas sob regulamentação de Zona Azul é permitido, contanto que obedeça aos requisitos municipais locais e que as taxas de permanência relativas ao zoneamento sejam recolhidas/autorizadas pela CET. Fale conosco para darmos o suporte na escolha do melhor posicionamento.
						</div>
					</div>
				</div>

				<!-- FAQ Item 4 -->
				<div class="border border-slate-200 rounded-3xl overflow-hidden bg-slate-50 transition-colors duration-300 faq-item">
					<button class="w-full flex justify-between items-center p-6 md:p-8 text-left focus:outline-none select-none faq-trigger">
						<span class="font-extrabold text-base md:text-lg text-slate-900 leading-tight">O que significa a sigla CTR?</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500 transition-transform duration-300 faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
						</svg>
					</button>
					<div class="max-h-0 overflow-hidden transition-all duration-300 faq-content">
						<div class="px-6 pb-6 md:px-8 md:pb-8 text-xs md:text-sm text-slate-600 leading-relaxed border-t border-slate-200/50 pt-4">
							O CTR (Controle de Transporte de Resíduos) é o manifesto eletrônico emitido obrigatoriamente para comprovar que o entulho gerado na obra teve o destino adequado em uma Área de Transbordo e Triagem (ATT) ou aterro homologado. O CTR garante que sua obra esteja regular perante a fiscalização municipal.
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Script -->
	<script is:inline>
		document.addEventListener('DOMContentLoaded', () => {
			const triggers = document.querySelectorAll('.faq-trigger');
			triggers.forEach(trigger => {
				trigger.addEventListener('click', () => {
					const item = trigger.closest('.faq-item');
					const content = item.querySelector('.faq-content');
					const icon = item.querySelector('.faq-icon');
					const isOpen = item.classList.contains('active');

					// Close all other items
					document.querySelectorAll('.faq-item').forEach(otherItem => {
						otherItem.classList.remove('active');
						otherItem.querySelector('.faq-content').style.maxHeight = '0px';
						otherItem.querySelector('.faq-icon').style.transform = 'rotate(0deg)';
						otherItem.classList.remove('bg-white');
						otherItem.classList.add('bg-slate-50');
					});

					if (!isOpen) {
						item.classList.add('active');
						content.style.maxHeight = content.scrollHeight + 'px';
						icon.style.transform = 'rotate(180deg)';
						item.classList.remove('bg-slate-50');
						item.classList.add('bg-white');
					}
				});
			});
		});
	</script>

	<!-- 6. Call To Action -->
	<section class="bg-gradient-to-b from-white to-slate-100 border-t border-slate-200/60 py-24">
		<div class="container mx-auto px-6 md:px-12 text-center max-w-3xl">
			<h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tighter mb-6 leading-tight">
				Pronto para Solicitar sua Caçamba?
			</h2>
			<p class="text-lg text-slate-600 mb-10 max-w-xl mx-auto leading-relaxed">
				Fale conosco agora por WhatsApp. Nossa equipe calcula a caçamba correta e passa o orçamento na hora.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a href={SITE_CONFIG.whatsapp.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-xl text-base font-black bg-primary text-accent hover:bg-yellow-400 hover:scale-105 active:scale-95 transition-all duration-200 shadow-lg shadow-primary/30">
					<!-- WhatsApp SVG -->
					<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0 fill-accent" viewBox="0 0 24 24">
						<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.5-5.719-1.455L0 24zm6.59-4.846c1.6.95 3.498 1.453 5.418 1.454h.005c5.548 0 10.061-4.515 10.064-10.067.002-2.69-1.043-5.22-2.943-7.123C17.23 1.516 14.7 1.011 12.008 1.01 6.458 1.01 1.947 5.524 1.944 11.077c-.001 1.916.501 3.788 1.457 5.4l-.956 3.493 3.585-.94c1.552.846 3.298 1.291 5.068 1.291z M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
					</svg>
					Pedir Orçamento no WhatsApp
				</a>
				<a href="/contato" class="inline-flex items-center justify-center px-8 py-4 rounded-xl text-base font-black border border-slate-300 text-slate-700 hover:bg-slate-100 hover:scale-105 active:scale-95 transition-all duration-200">
					Formulário de Contato
				</a>
			</div>
		</div>
	</section>
</Layout>
